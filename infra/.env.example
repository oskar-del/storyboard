# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Go API (apps/api) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.your-project.supabase.co:5432/postgres
JWT_SECRET=your-supabase-jwt-secret       # from Supabase Settings > API > JWT Secret
PORT=8080
ANTHROPIC_API_KEY=your-anthropic-api-key  # used by /capture/process endpoint

# ── Next.js frontend (apps/web) ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080         # set to Railway URL in production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── MCP server (apps/mcp) ─────────────────────────────────────────────────────
STORYBOARD_API_URL=http://localhost:8080          # set to Railway URL in production
STORYBOARD_TOKEN=your-user-jwt-or-service-token
STORYBOARD_AUTHOR=oskar
STORYBOARD_COLLAB_PROJECTS=Storyboard            # comma-separated, must match project names

# ── Data migration script (infra/scripts/) ────────────────────────────────────
# SUPABASE_URL and SUPABASE_SERVICE_KEY from above are also used here
LEGACY_BLOCKS_PATH=/path/to/legacy/storyboard/blocks-data.json
LEGACY_VAULT_DIR=/Users/yourname/Dropbox/Storyboard-Vault
COLLAB_PROJECTS=Storyboard
